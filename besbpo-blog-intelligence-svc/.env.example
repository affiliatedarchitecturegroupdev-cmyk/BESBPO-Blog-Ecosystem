PORT=8000
CMS_CORE_API_URL=http://localhost:3000

# Anthropic (Claude) — leave empty to run entirely on the deterministic
# heuristic fallbacks (no external calls, no cost, no API key needed).
# Set both to enable real tagging/SEO/summarisation proposals.
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5

# Voyage AI — Anthropic's recommended embeddings partner (Claude has no
# first-party embeddings API; see besbpo-blog-architecture's ADR 0004).
# Leave VOYAGE_API_KEY empty to fall back to the Phase 0 placeholder
# pseudo-embedding (structurally valid, NOT semantically meaningful).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
# Must match the pgvector column width in
# besbpo-blog-architecture/db/schema.sql — change both together.
EMBEDDING_DIMENSIONS=1024
