NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://besbpo:besbpo@localhost:5432/besbpo_blog

JWT_SECRET=replace-me-in-coolify-env
JWT_EXPIRES_IN=15m

SYNDICATION_SERVICE_URL=http://localhost:8080

# Phase 9: real embedding generation on publish (see
# src/embeddings/embedding.service.ts). Leave unset to skip embedding
# generation entirely (articles publish fine either way — this is
# best-effort and never blocks a publish) — matches this platform's
# fixture/heuristic-fallback philosophy elsewhere.
INTELLIGENCE_SERVICE_URL=http://localhost:8000

# Phase 9+: media upload (see src/media/). Leave AWS_S3_BUCKET unset to
# store uploads on local disk instead (LocalFilesystemStorageBackend) --
# fine for local dev, NOT suitable for anything beyond it (see that
# class's doc comment: no persistence across redeploys, not served back
# over HTTP).
AWS_REGION=af-south-1
AWS_S3_BUCKET=
# Set if the bucket sits behind a CDN/custom domain; otherwise the
# bucket's own regional S3 endpoint URL is used.
AWS_S3_PUBLIC_BASE_URL=

# Audit trail (see src/audit/). Leave unset to skip audit recording
# entirely -- field approvals and status transitions still work fine
# either way (this is best-effort and never blocks the action itself),
# matching this platform's fixture/heuristic-fallback philosophy elsewhere.
ENTERPRISE_SERVICE_URL=http://localhost:8082
