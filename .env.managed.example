# BESBPO Blog Platform - Managed Services Environment Variables
# Reference: Master Plan Section 4
#
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# =============================================================================
# SUPABASE (PostgreSQL + Auth + Storage)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

SUPABASE_PROJECT_ID=your-project-id
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_POSTGRES_PASSWORD=your-secure-password

# =============================================================================
# UPSTASH REDIS
# =============================================================================
# Get these from: https://console.upstash.com/

UPSTASH_REDIS_REST_URL=https://[region].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# JWT SECRET
# =============================================================================
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=generate-a-secure-random-string

# =============================================================================
# CMS API
# =============================================================================
CMS_API_URL=https://api.besbpo.co.za
NEXT_PUBLIC_CMS_API_URL=https://api.besbpo.co.za

# =============================================================================
# AWS (for S3 media storage)
# =============================================================================
# Note: With OIDC, we don't need static AWS credentials
# These are only needed for S3 bucket access

AWS_S3_BUCKET=besbpo-blog-media
AWS_REGION=eu-west-1

# =============================================================================
# AI APIs
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# =============================================================================
# GitHub Actions OIDC (for CI/CD)
# =============================================================================
# These are set in GitHub repository settings, not in .env
# See infrastructure/aws/oidc.tf for IAM role configuration

# AWS_REGION=eu-west-1
# PROD_GITHUB_ACTIONS_ROLE_ARN=arn:aws:iam::123456789:role/besbpo-github-actions-production
# STAGING_GITHUB_ACTIONS_ROLE_ARN=arn:aws:iam::123456789:role/besbpo-github-actions-staging
