# besbpo-blog-web — Local development with hot reload
# Production builds use the GitHub Actions workflow (see .github/workflows/)
FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source (volume mount will override for development)
COPY . .

# Expose port
EXPOSE 3002
ENV PORT=3002

# Development command with hot reload
CMD ["npm", "run", "dev"]
