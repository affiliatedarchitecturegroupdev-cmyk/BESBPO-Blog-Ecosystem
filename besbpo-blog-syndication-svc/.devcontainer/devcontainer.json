{
  "name": "BESBPO Syndication Service",
  "image": "mcr.microsoft.com/devcontainers/images/tutorial-go:1.22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Syndication API",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "go mod download",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "golang.go"
      },
      "extensions": [
        "golang.go",
        "ms-vscode.go"
      ]
    }
  }
}
