PORT=8080

# Set DATABASE_URL to switch from in-memory backends to real Postgres/Redis
# (see internal/config/config.go's UseInMemoryBackends). Leave unset for
# local development against the Phase 0 in-memory implementations.
DATABASE_URL=postgres://besbpo:besbpo@localhost:5432/besbpo_blog
REDIS_URL=redis://localhost:6379

# Or force one way or the other regardless of DATABASE_URL:
# USE_IN_MEMORY_BACKENDS=true

SERVICE_JWT_SECRET=replace-me-in-coolify-env
ADMIN_JWT_SECRET=replace-me-in-coolify-env
# IMPORTANT: besbpo-blog-cms-api currently signs every JWT it issues with a
# single JWT_SECRET (see its AuthModule) — it does not yet distinguish an
# "admin" signing key from a "service" signing key. Until that's added,
# BOTH of the above must be set to the SAME value as besbpo-blog-cms-api's
# JWT_SECRET, or token verification here will always fail. See the header
# comment in internal/middleware/jwt.go for the full explanation.
#
# ADMIN_JWT_SECRET does double duty as of Phase 9: this service also uses
# it to SIGN a short-lived admin-shaped JWT for its own outbound calls to
# besbpo-blog-cms-api's GET /articles (see middleware.SignAdminJWT and
# internal/feed/cms_source.go) — replacing a static bearer token
# (CMS_SERVICE_TOKEN, removed) that stopped working once that endpoint
# gained a real JwtAuthGuard.
CMS_CORE_API_URL=http://localhost:3000

# Fine-grained GitHub PAT (or GitHub App installation token), scoped only to
# contents:write + actions:write on the specific subsidiary-site repos this
# service dispatches to (Doc-04 Section 5).
GITHUB_DISPATCH_TOKEN=replace-me-in-coolify-env

DEFAULT_RATE_LIMIT_RPM=60
HIGH_TIER_RATE_LIMIT_RPM=300
