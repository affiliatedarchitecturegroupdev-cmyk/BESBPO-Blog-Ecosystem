PORT=8082

# Phase 7: real Postgres-backed audit persistence (was in-memory).
DATABASE_URL=jdbc:postgresql://localhost:5432/besbpo_blog
DATABASE_USER=besbpo
DATABASE_PASSWORD=besbpo

# Phase 7: real HS256 service-JWT verification on /api/v1/audit.
# IMPORTANT: must match besbpo-blog-cms-api's JWT_SECRET and
# besbpo-blog-syndication-svc's SERVICE_JWT_SECRET/ADMIN_JWT_SECRET — all
# four currently sign/verify with one shared secret across three
# languages/services until distinct signing keys per purpose are
# introduced. See za.co.besbpo.enterprise.security.ServiceJwtVerifier's
# class doc comment for why this is verified with a hand-rolled HMAC
# check instead of a JWT library (JJWT's minimum-key-length enforcement
# would reject short dev secrets like the default below).
SERVICE_JWT_SECRET=dev-secret-change-me
