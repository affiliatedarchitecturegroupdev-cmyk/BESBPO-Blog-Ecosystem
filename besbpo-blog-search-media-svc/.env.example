PORT=8081

# Set to sync published articles (and their pgvector embeddings, where
# generated) from Postgres every 60s. Leave unset to run on a single
# hardcoded seed document instead (matches this platform's fixture-
# fallback philosophy elsewhere — see besbpo-blog-web's lib/api.ts).
DATABASE_URL=postgres://besbpo:besbpo@localhost:5432/besbpo_blog
