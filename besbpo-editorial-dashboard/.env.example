PORT=3001

# Real per-user login now exists (see README's "Real per-user identity"
# section) -- log in at /login and everything below becomes a fallback
# for local dev without logging in, not the primary auth path anymore.
# SYNDICATION_ADMIN_JWT/CMS_API_ADMIN_JWT are only ever used when no
# session cookie is present.

# Leave both empty to run entirely on fixture data (lib/fixtures/analytics-summary.json)
# — good for local dev/design review without a live syndication service.
SYNDICATION_API_BASE_URL=http://localhost:8080
# A manually-generated admin JWT -- fallback only, see above.
SYNDICATION_ADMIN_JWT=

# Same pattern for the authoring UI (article list/edit/create), added
# alongside it — leave both empty to run on lib/fixtures/articles.json
# instead. Reads/writes go through besbpo-blog-cms-api, not
# besbpo-blog-syndication-svc, so this is a separate base URL/token pair
# even though they're conceptually the same kind of stand-in credential.
CMS_API_BASE_URL=http://localhost:3000
CMS_API_ADMIN_JWT=
